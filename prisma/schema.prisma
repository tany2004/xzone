generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SeatType {
  PC
  PS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum PricingPeriod {
  MORNING      // 08:00–12:00
  DAY          // 12:00–17:00
  EVENING      // 17:00–08:00
  PACK_3H      // Пакет 3 часа
  PACK_5H      // Пакет 5 часов
  NIGHT_WEEKDAY   // Ночной будни 21:00–07:30
  NIGHT_WEEKEND   // Ночной выходные 21:00–07:30
  HOURLY       // PS5 почасовой
}

model Club {
  id      String  @id @default(uuid())
  name    String
  address String
  phone   String

  halls        Hall[]
  pricingRules PricingRule[]
}

model Hall {
  id       String   @id @default(uuid())
  clubId   String
  name     String
  type     SeatType

  club  Club   @relation(fields: [clubId], references: [id])
  seats Seat[]
}

model Seat {
  id        String   @id @default(uuid())
  hallId    String
  label     String
  seatType  SeatType
  isBlocked Boolean  @default(false)

  hall     Hall      @relation(fields: [hallId], references: [id])
  bookings Booking[]
}

model Booking {
  id          String        @id @default(uuid())
  seatId      String
  bookingCode String        @unique
  clientName  String
  clientPhone String
  startsAt    DateTime
  endsAt      DateTime
  status      BookingStatus @default(PENDING)
  totalPrice  Int
  createdAt   DateTime      @default(now())

  seat Seat @relation(fields: [seatId], references: [id])
}

model Blacklist {
  id          String   @id @default(uuid())
  clientPhone String   @unique
  clientName  String   // последнее известное имя
  reason      String?  // комментарий администратора
  noShowCount Int      @default(1) // сколько раз не пришёл
  addedAt     DateTime @default(now())
  addedBy     String   // login администратора

  admin Admin @relation(fields: [addedBy], references: [id])
}

model PricingRule {
  id           String        @id @default(uuid())
  clubId       String
  seatType     SeatType
  period       PricingPeriod
  pricePerHour Decimal       @db.Decimal(10, 2)

  club Club @relation(fields: [clubId], references: [id])
}

model Admin {
  id           String @id @default(uuid())
  login        String @unique
  passwordHash String

  blacklist    Blacklist[]
}